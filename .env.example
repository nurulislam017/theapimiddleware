# Generate app keys with: php artisan key:generate --show (or run ./setup.sh)
FIONA_APP_KEY=base64:REPLACE_WITH_GENERATED_KEY
PLUCKER_APP_KEY=base64:REPLACE_WITH_GENERATED_KEY

# MySQL
DB_ROOT_PASSWORD=supersecretrootpassword
DB_DATABASE=apimiddleware
DB_USERNAME=apimiddleware
DB_PASSWORD=supersecretpassword

# Set to production for live deployments
APP_ENV=local
APP_DEBUG=true

# OAuth — leave blank to disable a provider (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_APP_ID=
MICROSOFT_CLIENT_SECRET=
